{
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": "off"
  },
  "globals": {
    "React": "readonly",
    "require": "readonly",
    "process": "readonly",
    "module": "readonly"
  }
}
