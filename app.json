{
  "expo": {
    "name": "AceTrack",
    "slug": "acetrack-mobile",
    "version": "2.6.191",
    "sdkVersion": "50.0.0",

    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "android": {
      "package": "com.acetrack",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.DETECT_SCREEN_CAPTURE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.acetrack"
    },
    "runtimeVersion": "2.0.0",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B82F6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "636e8270-95c8-44e0-bf6f-bb544a857002"
      }
    },
    "owner": "acetrack-suggested",
    "updates": {
      "url": "https://u.expo.dev/636e8270-95c8-44e0-bf6f-bb544a857002"
    }
  }
}
